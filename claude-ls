#!/usr/bin/env bash
# claude-ls — list Claude instances (active + recently closed) with names and
# colors, reconciling the registry against live tmux windows first.
#
#   claude-ls                    print the colored list
#   claude-ls --reconcile-only   update the registry only (used by a tmux hook)
#   claude-ls --prune [N]        trim closed history to the newest N (default 50)
#   claude-ls --clean-backups    remove registry migration backups
set -eo pipefail
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/lib.sh"

[ "${1:-}" = "--clean-backups" ] && { cs_clean_backups; echo "removed registry migration backups."; exit 0; }

cs_reconcile
[ "${1:-}" = "--reconcile-only" ] && exit 0
if [ "${1:-}" = "--prune" ]; then
  cs_prune "${2:-50}"; echo "pruned closed history (kept newest ${2:-50})"; exit 0
fi

# One-time notice after an auto-migration (never shown inside the hook above).
if [ -f "$(cs_state_dir)/.migrated" ]; then
  printf '\033[2m(registry upgraded to a new format; a backup was kept — remove it with: claude-ls --clean-backups)\033[0m\n\n'
fi

# Render the JSONL registry to a temp TSV (legacy column order) so the existing
# awk passes — including the two-file status-map join below — are unchanged.
reg="$(mktemp)"; trap 'rm -f "$reg"' EXIT
cs_rows > "$reg"
now="$(date +%s)"

printf '\033[1mclaude instances\033[0m — session: %s\n\n' "$(cs_session)"

printf '\033[1mactive\033[0m\n'
if [ -f "$reg" ] && awk -F'\t' '$7=="active"{f=1} END{exit !f}' "$reg"; then
  smap="$(mktemp)"
  for sf in "$(cs_status_dir)"/*; do [ -f "$sf" ] && printf '%s\t%s\n' "$(basename "$sf")" "$(cut -f1 "$sf")"; done > "$smap" 2>/dev/null
  awk -F'\t' -v now="$now" -v smapf="$smap" '
    function dur(s,  d){d=now-s; if(d<60)return d"s"; if(d<3600)return int(d/60)"m";
      if(d<86400)return int(d/3600)"h"int((d%3600)/60)"m"; return int(d/86400)"d"}
    function mbadge(m,e){ if(m==""&&e=="")return ""; if(e=="")return " \033[2m{"m"}\033[0m";
      if(m=="")return " \033[2m{@"e"}\033[0m"; return " \033[2m{"m" @"e"}\033[0m" }
    function instline(L,  f,id,st,sb){ split(L,f,"\t");
      id=(f[9]==""?"":" \033[2m["substr(f[9],1,8)"]\033[0m"); st=S[f[4]]; sb="";
      if(st=="needs-approval") sb="  \033[1;33m⚠ needs approval\033[0m";
      else if(st=="working")   sb="  \033[36m⚙ working\033[0m";
      else if(st=="idle")      sb="  \033[2midle\033[0m";
      return sprintf("  \033[38;5;%sm●\033[0m %-16s %-28s up %s%s%s%s",
        f[2],f[1],f[5],dur(f[6]),mbadge(f[10],f[11]),sb,id) }
    # Ephemeral shells render indented under their parent instance (grouped).
    function shline(L,  f){ split(L,f,"\t");
      return sprintf("    \033[38;5;%sm\342\224\224\342\224\200\033[0m \033[2m%-14s %-28s up %s\033[0m",
        f[2],f[1],f[5],dur(f[6])) }
    FILENAME==smapf { S[$1]=$2; next }
    $7=="active" && $12!="shell" { ord[++ni]=$0; iswid[$4]=1 }
    $7=="active" && $12=="shell" { sh[$13]=sh[$13] (sh[$13]?"\036":"") $0; all[++na]=$0 }
    END {
      for(i=1;i<=ni;i++){ split(ord[i],f,"\t"); print instline(ord[i]);
        if(f[4] in sh){ m=split(sh[f[4]],a,"\036"); for(j=1;j<=m;j++) print shline(a[j]) } }
      for(k=1;k<=na;k++){ split(all[k],f,"\t");
        if(!(f[13] in iswid)){ if(!orph++) print "  \033[2mdetached shells\033[0m"; print shline(all[k]) } }
    }
  ' "$smap" "$reg"
  rm -f "$smap"
else
  printf '  (none)\n'
fi

printf '\n\033[1mclosed\033[0m\n'
if [ -f "$reg" ] && awk -F'\t' '$7=="closed" && $12!="shell"{f=1} END{exit !f}' "$reg"; then
  awk -F'\t' -v now="$now" '
    function ago(s,  d){if(s=="")return "?"; d=now-s; if(d<3600)return int(d/60)"m ago";
      if(d<86400)return int(d/3600)"h ago"; return int(d/86400)"d ago"}
    function badge(m,e){ if(m==""&&e=="")return ""; if(e=="")return " \033[2m{"m"}\033[0m";
      if(m=="")return " \033[2m{@"e"}\033[0m"; return " \033[2m{"m" @"e"}\033[0m" }
    $7=="closed" && $12!="shell"{ id=($9==""?"":" \033[2m["substr($9,1,8)"]\033[0m");   # shells are ephemeral, not listed when closed
      printf "  \033[38;5;%sm○\033[0m %-16s %-30s closed %s%s%s\n", $2,$1,$5,ago($8),badge($10,$11),id }
  ' "$reg" | tail -20
else
  printf '  (none)\n'
fi
