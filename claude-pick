#!/usr/bin/env bash
# claude-pick — interactive instance picker (scroll + type to filter):
#   * select an ACTIVE instance  -> switch tmux to its window
#   * select a CLOSED instance   -> reopen it, resuming its conversation in its
#       directory (so that project's CLAUDE.md + memory load too)
# Backs the menu's "List instances" / prefix+L. Without fzf, falls back to the
# read-only list.
set -eo pipefail
HERE="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
source "$HERE/lib.sh"

cs_reconcile
S="$(cs_session)"
reg="$(cs_registry)"
now="$(date +%s)"
[ -f "$reg" ] || { echo "no instances yet."; printf '\n[enter]'; read -r _; exit 0; }

if ! command -v fzf >/dev/null 2>&1; then
  "$HERE/claude-ls"; printf '\n\033[2m[fzf not installed — read-only list; enter to close]\033[0m '; read -r _; exit 0
fi

# fzf lines: status \t name \t window_id \t dir \t transcript \t model \t effort \t <display>
smap="$(mktemp)"
for sf in "$(cs_status_dir)"/*; do [ -f "$sf" ] && printf '%s\t%s\n' "$(basename "$sf")" "$(cut -f1 "$sf")"; done > "$smap" 2>/dev/null
lines="$(awk -F'\t' -v now="$now" '
  function ago(s,  d){d=now-s; if(d<60)return d"s"; if(d<3600)return int(d/60)"m";
    if(d<86400)return int(d/3600)"h"; return int(d/86400)"d"}
  function badge(m,e){ if(m==""&&e=="")return ""; if(e=="")return " {"m"}";
    if(m=="")return " {@"e"}"; return " {"m" @"e"}" }
  FNR==NR { S[$1]=$2; next }
  $7=="active"{ st=S[$4]; b=(st=="needs-approval"?" ⚠":(st=="working"?" ⚙":""));
    printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t\xE2\x97\x8F %-16s %-26s up %s%s%s\n", $7,$1,$4,$5,$9,$10,$11,$1,$5,ago($6),badge($10,$11),b }
  $7=="closed"{ printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t\xE2\x97\x8B %-16s %-26s closed %s ago%s\n",$7,$1,$4,$5,$9,$10,$11,$1,$5,ago($8),badge($10,$11) }
' "$smap" "$reg")"
rm -f "$smap"
[ -n "$lines" ] || { echo "no instances."; printf '\n[enter]'; read -r _; exit 0; }

sel="$(printf '%s\n' "$lines" | fzf --delimiter=$'\t' --with-nth='8..' \
        --prompt='instance> ' --height='100%' --reverse \
        --header='Enter: switch (active) / reopen (closed) · type to filter' 2>/dev/null)"
[ -n "$sel" ] || exit 0
IFS=$'\t' read -r status name wid dir transcript model effort _disp <<<"$sel"

if [ "$status" = active ]; then
  tmux select-window -t "$S:$wid" 2>/dev/null || tmux select-window -t "$S:$name" 2>/dev/null || true
  echo "switched to '$name'"
else
  dir="${dir:-$HOME}"
  me=(); [ -n "$model" ] && me+=(-M "$model"); [ -n "$effort" ] && me+=(-E "$effort")
  if [ -n "$transcript" ]; then exec "$HERE/claude-new" -i "$transcript" -c "$dir" -n "$name" "${me[@]}"
  else                          exec "$HERE/claude-new" -m continue -c "$dir" -n "$name" "${me[@]}"; fi
fi
