#!/usr/bin/env bash
# claude-restore — reopen a previously-closed instance from the registry, in its
# original directory (resumes that directory's most recent conversation).
# Picks with fzf if available, otherwise a numbered prompt. Meant to run inside
# a tmux popup (prefix+O / menu), but works standalone too.
set -eo pipefail
HERE="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
source "$HERE/lib.sh"

cs_reconcile

# Most recent closed instances first (de-dup by name).
# Each row: name<TAB>cwd<TAB>transcript<TAB>model<TAB>effort
mapfile -t rows < <(cs_rows | awk -F'\t' '$7=="closed"{print $8"\t"$1"\t"$5"\t"$9"\t"$10"\t"$11}' \
                    | sort -rn | awk -F'\t' '!seen[$2]++{print $2"\t"$3"\t"$4"\t"$5"\t"$6}')
[ "${#rows[@]}" -gt 0 ] || { echo "no closed instances to reopen."; exit 0; }

choice=""
if command -v fzf >/dev/null 2>&1; then
  choice="$(printf '%s\n' "${rows[@]}" \
    | awk -F'\t' '{printf "%-18s %s\n",$1,$2}' \
    | fzf --prompt='reopen closed > ' --height=100% || true)"
  choice="${choice%% *}"
else
  echo "closed instances — pick one to reopen:"
  i=1; for r in "${rows[@]}"; do
    IFS=$'\t' read -r rn rc _ <<<"$r"; printf "  %2d) %-18s %s\n" "$i" "$rn" "$rc"; i=$((i+1))
  done
  printf "number (Enter to cancel): "; read -r sel
  [ -n "${sel:-}" ] || { echo "cancelled."; exit 0; }
  choice="$(printf '%s\n' "${rows[@]}" | sed -n "${sel}p" | cut -f1)"
fi
[ -n "$choice" ] || { echo "cancelled."; exit 0; }

# Pull dir + transcript + model/effort for the chosen name. Use cut (cs_field),
# not `IFS=$'\t' read`, which collapses consecutive tabs and mis-parses empties.
sel_row="$(printf '%s\n' "${rows[@]}" | awk -F'\t' -v n="$choice" '$1==n{print; exit}')"
dir="$(cs_field 2 "$sel_row")"; transcript="$(cs_field 3 "$sel_row")"
model="$(cs_field 4 "$sel_row")"; effort="$(cs_field 5 "$sel_row")"
dir="${dir:-$HOME}"

# Offer to change the directory (completion/typeahead; keep the saved one or override).
dir="$(cs_pick_dir "$dir")"
dir="${dir/#\~/$HOME}"
[ -d "$dir" ] || { echo "no such directory: $dir"; exit 1; }

me=(); [ -n "$model" ] && me+=(-M "$model"); [ -n "$effort" ] && me+=(-E "$effort")
if [ -n "$transcript" ]; then
  echo "reopening '$choice' in $dir (exact conversation $transcript) ..."
  exec "$HERE/claude-new" -i "$transcript" -c "$dir" -n "$choice" "${me[@]}"
else
  echo "reopening '$choice' in $dir (most recent conversation there) ..."
  exec "$HERE/claude-new" -m continue -c "$dir" -n "$choice" "${me[@]}"
fi
