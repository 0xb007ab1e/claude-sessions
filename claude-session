#!/usr/bin/env bash
# claude-session — spin up (or attach to) a tmux session with one Claude Code
# instance per window. Phone-friendly (Tailscale + Termux) via the bundled
# tmux.conf. No machine-, user-, or path-specific assumptions.
#
# Usage:
#   claude-session [options] [name[:dir[:mode]] ...]
#
# Each positional argument becomes a tmux window:
#   name              window label (runs `claude`)
#   name:dir          + starting directory (a leading ~ is expanded)
#   name:dir:mode     + resume mode, one of:
#                         continue -> claude --continue
#                         resume   -> claude --resume
#                         new | '' -> claude   (fresh; the default)
#                     Set only the mode with an empty dir: name::resume
#
# Options:
#   -s NAME   session name (default: $CLAUDE_TMUX_SESSION or "claude")
#   -g        create a GROUPED attach view (independent size) of an existing
#             session — use from a second client (e.g. phone) so it doesn't
#             resize the other client's display
#   -n        no-attach: create the session but stay detached
#   -h        show this help
#
# Examples:
#   claude-session frontend backend docs
#   claude-session api:~/src/api web:~/src/web
#   claude-session app:~/src/app:continue notes::resume
#   claude-session -s review pr1 pr2
#   ssh <host> -t 'claude-session -g'        # grouped attach from another machine

set -euo pipefail

# Resolve the bundled config even when invoked via a symlink on PATH.
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
CONF="$(cd "$(dirname "$SELF")" && pwd)/tmux.conf"
SESSION="${CLAUDE_TMUX_SESSION:-claude}"
GROUPED=0
ATTACH=1

# Print the contiguous comment header (after the shebang) as help.
usage() { awk 'NR>1 && /^#/{sub(/^# ?/,""); print; next} NR>1{exit}' "$SELF"; exit "${1:-0}"; }

while getopts ":s:gnh" opt; do
  case "$opt" in
    s) SESSION="$OPTARG" ;;
    g) GROUPED=1 ;;
    n) ATTACH=0 ;;
    h) usage 0 ;;
    \?) echo "unknown option: -$OPTARG" >&2; usage 1 ;;
    :) echo "option -$OPTARG needs a value" >&2; usage 1 ;;
  esac
done
shift $((OPTIND - 1))

# Default window set when none are given.
[ "$#" -eq 0 ] && set -- main

tmux="tmux -f $CONF"

in_tmux() { [ -n "${TMUX:-}" ]; }

attach_or_switch() {
  local target="$1"
  if in_tmux; then tmux switch-client -t "$target"; else $tmux attach-session -t "$target"; fi
}

# Map a mode keyword to the command launched in the window.
claude_cmd() {
  case "${1:-}" in
    continue) echo 'claude --continue' ;;
    resume)   echo 'claude --resume' ;;
    *)        echo 'claude' ;;
  esac
}

# Grouped view: a throwaway session sharing the base session's windows but
# sized to THIS client. Lets a second client attach without resizing the first.
if [ "$GROUPED" -eq 1 ]; then
  if ! $tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "no base session '$SESSION' to group with — start it first" >&2
    exit 1
  fi
  if in_tmux; then
    # Inside tmux: make a detached grouped view, switch to it (now attached),
    # THEN mark destroy-unattached so it isn't culled while briefly detached.
    view="${SESSION}-$$"
    $tmux new-session -d -t "$SESSION" -s "$view"
    $tmux switch-client -t "$view"
    $tmux set-option -t "$view" destroy-unattached on
  else
    # From a bare shell (e.g. phone SSH): attach in a single invocation so the
    # grouped session is never unattached, then self-destruct on disconnect.
    exec $tmux new-session -t "$SESSION" \; set-option destroy-unattached on
  fi
  exit 0
fi

# If the base session already exists, just attach — don't recreate windows.
if $tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "session '$SESSION' already exists — attaching"
  [ "$ATTACH" -eq 1 ] && attach_or_switch "$SESSION"
  exit 0
fi

# Build the session: first window seeds it, the rest are added.
first=1
first_label=""
for entry in "$@"; do
  IFS=: read -r label dir mode <<<"$entry"
  [ -n "$dir" ] && dir="${dir/#\~/$HOME}"   # expand a leading ~
  cmd="$(claude_cmd "$mode")"

  if [ "$first" -eq 1 ]; then
    $tmux new-session -d -s "$SESSION" -n "$label" ${dir:+-c "$dir"}
    first=0; first_label="$label"
  else
    $tmux new-window -t "$SESSION" -n "$label" ${dir:+-c "$dir"}
  fi
  # Sent as keys so the shell stays if claude exits.
  $tmux send-keys -t "${SESSION}:${label}" "$cmd" C-m
done

# Select by name, not index — correct whether base-index is 0 or 1.
$tmux select-window -t "${SESSION}:${first_label}"

echo "started session '$SESSION' with windows: $*"
if [ "$ATTACH" -eq 1 ]; then
  attach_or_switch "$SESSION"
else
  echo "detached. attach with:  tmux attach -t $SESSION"
  echo "grouped from another client:  ssh \$(hostname -s) -t 'claude-session -g -s $SESSION'"
fi
