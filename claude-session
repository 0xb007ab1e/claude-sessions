#!/usr/bin/env bash
# claude-session — spin up (or attach to) a tmux session with one Claude Code
# instance per window, tuned for viewing from a phone over Tailscale + Termux.
#
# Usage:
#   claude-session [options] [name[:dir] ...]
#
# Each positional argument becomes a tmux window running `claude`.
#   name        window label
#   name:dir    window label + starting directory for that instance
#
# Options:
#   -s NAME     session name (default: claude)
#   -g          create a GROUPED attach view (independent size) instead of
#               creating/attaching the base session — use this from the phone
#               so it doesn't shrink the laptop's display
#   -n          no-attach: create the session but stay detached
#   -h          show this help
#
# Examples:
#   claude-session frontend backend docs
#   claude-session api:~/src/api web:~/src/web
#   claude-session -s review pr1 pr2          # second session named "review"
#   ssh parrot -t 'claude-session -g'         # attach from phone, own size

set -euo pipefail

CONF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/tmux.conf"
SESSION="claude"
GROUPED=0
ATTACH=1

usage() { sed -n '2,30p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit "${1:-0}"; }

while getopts ":s:gnh" opt; do
  case "$opt" in
    s) SESSION="$OPTARG" ;;
    g) GROUPED=1 ;;
    n) ATTACH=0 ;;
    h) usage 0 ;;
    \?) echo "unknown option: -$OPTARG" >&2; usage 1 ;;
    :) echo "option -$OPTARG needs a value" >&2; usage 1 ;;
  esac
done
shift $((OPTIND - 1))

# Default window set when none are given.
if [ "$#" -eq 0 ]; then
  set -- main
fi

tmux="tmux -f $CONF"

# Are we inside a tmux client already? Use switch-client instead of attach.
in_tmux() { [ -n "${TMUX:-}" ]; }

attach_or_switch() {
  local target="$1"
  if in_tmux; then
    tmux switch-client -t "$target"
  else
    $tmux attach-session -t "$target"
  fi
}

# Grouped view: a throwaway session sharing the base session's windows but
# sized to THIS client. Lets the phone attach without resizing the laptop.
if [ "$GROUPED" -eq 1 ]; then
  if ! $tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "no base session '$SESSION' to group with — start it first" >&2
    exit 1
  fi
  if in_tmux; then
    # Inside tmux: make a detached grouped view, switch to it (now attached),
    # THEN mark destroy-unattached so it isn't culled while briefly detached.
    view="${SESSION}-$$"
    $tmux new-session -d -t "$SESSION" -s "$view"
    $tmux switch-client -t "$view"
    $tmux set-option -t "$view" destroy-unattached on
  else
    # From a bare shell (e.g. phone SSH): attach in a single invocation so the
    # grouped session is never unattached, then self-destruct on disconnect.
    exec $tmux new-session -t "$SESSION" \; set-option destroy-unattached on
  fi
  exit 0
fi

# If the base session already exists, just attach — don't recreate windows.
if $tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "session '$SESSION' already exists — attaching"
  [ "$ATTACH" -eq 1 ] && attach_or_switch "$SESSION"
  exit 0
fi

# Build the session: first window seeds it, the rest are added.
first=1
first_label=""
for entry in "$@"; do
  label="${entry%%:*}"
  dir=""
  if [ "$entry" != "$label" ]; then
    dir="${entry#*:}"
    dir="${dir/#\~/$HOME}"   # expand a leading ~
  fi

  if [ "$first" -eq 1 ]; then
    $tmux new-session -d -s "$SESSION" -n "$label" ${dir:+-c "$dir"}
    first=0
    first_label="$label"
  else
    $tmux new-window -t "$SESSION" -n "$label" ${dir:+-c "$dir"}
  fi
  # Launch Claude in that window. Sent as keys so the shell stays if claude exits.
  $tmux send-keys -t "${SESSION}:${label}" 'claude' C-m
done

# Select by name, not index — correct whether base-index is 0 or 1.
$tmux select-window -t "${SESSION}:${first_label}"

echo "started session '$SESSION' with windows: $*"
if [ "$ATTACH" -eq 1 ]; then
  attach_or_switch "$SESSION"
else
  echo "detached. attach with:  tmux attach -t $SESSION"
  echo "from phone (own size):  ssh parrot -t 'claude-session -g -s $SESSION'"
fi
