# claude-sessions configuration — copy to ~/.config/claude-sessions/config
# Format: `key = value`, with # for comments.

# Naming convention for auto-named instances: nato | project | random
#   nato     -> alpha, bravo, charlie, …   (stable color per call-sign)
#   project  -> <cwd-basename>-N           (color hashed from the name)
#   random   -> <adjective>-<noun>         (color hashed from the name)
name_scheme = nato

# Auto-name every instance started via `cj` even without the -a flag.
auto_name = false

# Default model / effort for new instances (per-instance override on the CLI
# with `cj -M MODEL -E EFFORT` or `claude-new -M MODEL -E EFFORT`, or via the
# menu's "New (model)…" / prefix+M). Empty = Claude's own defaults.
#   default_model  : alias (sonnet | opus | haiku) or full id (e.g. claude-opus-4-8)
#   default_effort : low | medium | high | xhigh | max
# default_model  =
# default_effort =

# Root directory for the "New in dir…" / reopen picker. The picker walks the
# tree one level at a time, shows entries RELATIVE to this root, and is floored
# here — you can't navigate above it. Default: $HOME. Point it at where your
# projects live (e.g. ~/_src/_dev) to keep things tight.
search_dir = ~

# Allow the picker to navigate ABOVE search_dir. When true, ".." at the root and
# the in-picker Alt-u key ascend past the floor; when false they're locked.
allow_dir_escape = false

# Attention notifications when an instance needs you (via the Claude Code hooks
# installed by install.sh — fires on a permission/approval prompt; also the tmux
# terminal-bell path).
#   notify = desktop | ntfy | pushover | none
notify = desktop
# For phone push over Tailscale via ntfy (https://ntfy.sh or self-hosted):
# notify      = ntfy
# ntfy_server = https://ntfy.sh
# ntfy_topic  = my-claude-alerts   (or run: claude-notify --set-topic [slug])
# For Pushover:
# notify         = pushover
# pushover_token = <app token>
# pushover_user  = <user key>
# With the Claude Code hooks installed (install.sh), notifications fire precisely
# when an instance needs approval. Also ping when an instance *finishes* a turn:
notify_on_finish = false

# Reopen the previous session's instances automatically at boot (the systemd
# service snapshots active instances on stop and reopens them on start).
restore_on_boot = false

# Watchdog: auto-restart CRASHED instances in place, resuming the conversation.
# Opt-in — when true, re-run ./install.sh so the pane-died hook is wired up.
#   watchdog              : master switch
#   watchdog_restart_on   : crash (exit≠0, default) | always | never
#   watchdog_max_retries  : give up after this many restarts within the window
#   watchdog_window       : seconds; surviving longer resets the retry count
#   watchdog_backoff      : seconds before respawn, doubled each retry
watchdog             = false
# watchdog_restart_on  = crash
# watchdog_max_retries = 3
# watchdog_window      = 60
# watchdog_backoff     = 5
