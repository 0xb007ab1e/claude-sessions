# claude-sessions tmux key bindings — generated by install.sh from this template
# (@BIN@ -> the install bin dir). Sourced from tmux.conf so it loads in the boot
# session and interactive attaches. Requires tmux >= 3.2. Prefix is Ctrl-b.
#
# Fluent design: the action menu is GROUPED with drill-down submenus (▸) using
# tmux { } command blocks. The flat direct keys below are kept for power users.

# ── Grouped action menu (prefix + C, F9, or tap the session name) ────────────
# Defined identically for the three triggers. Each top item drills into a group.
bind C display-menu -T "#[align=centre,bold] claude " \
  "▸ Instances"      i { display-menu -T "#[align=centre,bold] instances " \
        "Switch"            s { choose-tree -Zw } \
        "List / pick"       l { display-popup -E -w 84% -h 72% "@BIN@/claude-pick" } \
        "New"               n { run-shell "@BIN@/claude-new" } \
        "New in dir…"       d { display-popup -E -w 80% -h 70% "@BIN@/claude-new -D" } \
        "Rename"            e { display-popup -E -w 60% -h 28% "@BIN@/claude-rename" } \
        "Change dir"        c { display-popup -E -w 80% -h 70% "@BIN@/claude-cd" } \
        "Usage / cost"      u { display-popup -E -w 78% -h 60% "@BIN@/claude-popup cost" } \
        "Stop"              x { confirm-before -p "stop instance #W? (y/n)" kill-window } } \
  "▸ Conversations"  v { display-menu -T "#[align=centre,bold] conversations " \
        "Resume"            r { run-shell "@BIN@/claude-new -m resume" } \
        "Reopen closed"     o { display-popup -E -w 74% -h 74% "@BIN@/claude-restore" } \
        "Restore last"      a { run-shell "@BIN@/claude-restore-all" } } \
  "▸ Shell"          h { display-menu -T "#[align=centre,bold] shell " \
        "New shell here"    s { run-shell "@BIN@/claude-shell" } \
        "New shell in dir…" d { display-popup -E -w 80% -h 70% "@BIN@/claude-shell -D" } } \
  "▸ Model / effort" m { display-popup -E -w 60% -h 50% "@BIN@/claude-model" } \
  "▸ Help"           ? { display-popup -E -w 78% -h 82% "@BIN@/claude-popup help" }

bind -n F9 display-menu -T "#[align=centre,bold] claude " \
  "▸ Instances"      i { display-menu -T "#[align=centre,bold] instances " \
        "Switch"            s { choose-tree -Zw } \
        "List / pick"       l { display-popup -E -w 84% -h 72% "@BIN@/claude-pick" } \
        "New"               n { run-shell "@BIN@/claude-new" } \
        "New in dir…"       d { display-popup -E -w 80% -h 70% "@BIN@/claude-new -D" } \
        "Rename"            e { display-popup -E -w 60% -h 28% "@BIN@/claude-rename" } \
        "Change dir"        c { display-popup -E -w 80% -h 70% "@BIN@/claude-cd" } \
        "Usage / cost"      u { display-popup -E -w 78% -h 60% "@BIN@/claude-popup cost" } \
        "Stop"              x { confirm-before -p "stop instance #W? (y/n)" kill-window } } \
  "▸ Conversations"  v { display-menu -T "#[align=centre,bold] conversations " \
        "Resume"            r { run-shell "@BIN@/claude-new -m resume" } \
        "Reopen closed"     o { display-popup -E -w 74% -h 74% "@BIN@/claude-restore" } \
        "Restore last"      a { run-shell "@BIN@/claude-restore-all" } } \
  "▸ Shell"          h { display-menu -T "#[align=centre,bold] shell " \
        "New shell here"    s { run-shell "@BIN@/claude-shell" } \
        "New shell in dir…" d { display-popup -E -w 80% -h 70% "@BIN@/claude-shell -D" } } \
  "▸ Model / effort" m { display-popup -E -w 60% -h 50% "@BIN@/claude-model" } \
  "▸ Help"           ? { display-popup -E -w 78% -h 82% "@BIN@/claude-popup help" }

bind -n MouseDown1StatusLeft display-menu -T "#[align=centre,bold] claude " \
  "▸ Instances"      i { display-menu -T "#[align=centre,bold] instances " \
        "Switch"            s { choose-tree -Zw } \
        "List / pick"       l { display-popup -E -w 84% -h 72% "@BIN@/claude-pick" } \
        "New"               n { run-shell "@BIN@/claude-new" } \
        "New in dir…"       d { display-popup -E -w 80% -h 70% "@BIN@/claude-new -D" } \
        "Rename"            e { display-popup -E -w 60% -h 28% "@BIN@/claude-rename" } \
        "Change dir"        c { display-popup -E -w 80% -h 70% "@BIN@/claude-cd" } \
        "Usage / cost"      u { display-popup -E -w 78% -h 60% "@BIN@/claude-popup cost" } \
        "Stop"              x { confirm-before -p "stop instance #W? (y/n)" kill-window } } \
  "▸ Conversations"  v { display-menu -T "#[align=centre,bold] conversations " \
        "Resume"            r { run-shell "@BIN@/claude-new -m resume" } \
        "Reopen closed"     o { display-popup -E -w 74% -h 74% "@BIN@/claude-restore" } \
        "Restore last"      a { run-shell "@BIN@/claude-restore-all" } } \
  "▸ Shell"          h { display-menu -T "#[align=centre,bold] shell " \
        "New shell here"    s { run-shell "@BIN@/claude-shell" } \
        "New shell in dir…" d { display-popup -E -w 80% -h 70% "@BIN@/claude-shell -D" } } \
  "▸ Model / effort" m { display-popup -E -w 60% -h 50% "@BIN@/claude-model" } \
  "▸ Help"           ? { display-popup -E -w 78% -h 82% "@BIN@/claude-popup help" }

# ── Flat direct keys (power users; unchanged) ────────────────────────────────
bind L display-popup -E -w 84% -h 72% "@BIN@/claude-pick"
bind U display-popup -E -w 78% -h 60% "@BIN@/claude-popup cost"
bind N run-shell "@BIN@/claude-new"
bind D display-popup -E -w 80% -h 70% "@BIN@/claude-new -D"
bind M display-popup -E -w 60% -h 50% "@BIN@/claude-model"
bind G display-popup -E -w 80% -h 70% "@BIN@/claude-cd"
bind B run-shell "@BIN@/claude-shell"
bind E display-popup -E -w 60% -h 28% "@BIN@/claude-rename"
bind R run-shell "@BIN@/claude-new -m resume"
bind O display-popup -E -w 74% -h 74% "@BIN@/claude-restore"
bind X confirm-before -p "stop instance #W? (y/n)" kill-window
bind ? display-popup -E -w 78% -h 82% "@BIN@/claude-popup help"

# ── No-prefix navigation (works inside a full-screen Claude TUI) ─────────────
bind -n M-Left  previous-window
bind -n M-Right next-window
bind -n F7      previous-window
bind -n F8      next-window

# Status-bar summary: ⚠N need approval / ⚙N working (from claude-hook status).
set -g status-right '#(@BIN@/claude-status bar) #[fg=cyan]%H:%M #[fg=yellow]%d-%b'

# Keep the active/closed registry fresh when a window closes.
set-hook -g window-unlinked 'run-shell "@BIN@/claude-ls --reconcile-only"'

# Notify when an instance rings the bell (Claude finished / needs input).
set-hook -g alert-bell 'run-shell "@BIN@/claude-notify bell #{q:window_name} #{q:session_name}"'
