# claude-sessions tmux key bindings — generated by install.sh from this
# template. The single placeholder @BIN@ is replaced with the install bin dir
# (where cj / claude-ls / claude-new / claude-restore / claude-popup live).
# Sourced from tmux.conf, so it loads in both the boot session and interactive
# attaches. Requires tmux >= 3.2 (display-popup). Prefix is Ctrl-b by default.

# ── Action menu (prefix + C) ────────────────────────────────────────────────
bind C display-menu -T "#[align=centre,bold] claude instances " \
  "Switch instance"      s "choose-tree -Zw" \
  "List instances"       l "display-popup -E -w 84% -h 72% '@BIN@/claude-pick'" \
  "New instance"         n "run-shell '@BIN@/claude-new'" \
  "New in dir…"          d "display-popup -E -w 80% -h 70% '@BIN@/claude-new -D'" \
  "New (model)…"         m "display-popup -E -w 60% -h 50% '@BIN@/claude-model'" \
  "Change dir"           c "display-popup -E -w 80% -h 70% '@BIN@/claude-cd'" \
  "Rename instance"      e "display-popup -E -w 60% -h 28% '@BIN@/claude-rename'" \
  "Shell here"           b "run-shell '@BIN@/claude-shell'" \
  "Resume conversation"  r "run-shell '@BIN@/claude-new -m resume'" \
  "Reopen closed"        o "display-popup -E -w 74% -h 74% '@BIN@/claude-restore'" \
  "Restore last session" a "run-shell '@BIN@/claude-restore-all'" \
  "Stop current"         x "confirm-before -p 'stop instance #W? (y/n)' kill-window" \
  "Cheat sheet"          ? "display-popup -E -w 78% -h 82% '@BIN@/claude-popup help'"

# ── Direct keys ─────────────────────────────────────────────────────────────
bind L display-popup -E -w 84% -h 72% "@BIN@/claude-pick"
bind N run-shell "@BIN@/claude-new"
bind D display-popup -E -w 80% -h 70% "@BIN@/claude-new -D"
bind M display-popup -E -w 60% -h 50% "@BIN@/claude-model"
bind G display-popup -E -w 80% -h 70% "@BIN@/claude-cd"
bind B run-shell "@BIN@/claude-shell"
bind E display-popup -E -w 60% -h 28% "@BIN@/claude-rename"
bind R run-shell "@BIN@/claude-new -m resume"
bind O display-popup -E -w 74% -h 74% "@BIN@/claude-restore"
bind X confirm-before -p "stop instance #W? (y/n)" kill-window
bind ? display-popup -E -w 78% -h 82% "@BIN@/claude-popup help"

# ── No-prefix access (works INSIDE a full-screen Claude TUI) ─────────────────
# tmux intercepts these before the app, so no Ctrl-b is needed. F9 opens the
# same menu as prefix+C; Alt+arrows switch instances without leaving Claude.
bind -n F9 display-menu -T "#[align=centre,bold] claude instances " \
  "Switch instance"      s "choose-tree -Zw" \
  "List instances"       l "display-popup -E -w 84% -h 72% '@BIN@/claude-pick'" \
  "New instance"         n "run-shell '@BIN@/claude-new'" \
  "New in dir…"          d "display-popup -E -w 80% -h 70% '@BIN@/claude-new -D'" \
  "New (model)…"         m "display-popup -E -w 60% -h 50% '@BIN@/claude-model'" \
  "Change dir"           c "display-popup -E -w 80% -h 70% '@BIN@/claude-cd'" \
  "Rename instance"      e "display-popup -E -w 60% -h 28% '@BIN@/claude-rename'" \
  "Shell here"           b "run-shell '@BIN@/claude-shell'" \
  "Resume conversation"  r "run-shell '@BIN@/claude-new -m resume'" \
  "Reopen closed"        o "display-popup -E -w 74% -h 74% '@BIN@/claude-restore'" \
  "Restore last session" a "run-shell '@BIN@/claude-restore-all'" \
  "Stop current"         x "confirm-before -p 'stop instance #W? (y/n)' kill-window" \
  "Cheat sheet"          ? "display-popup -E -w 78% -h 82% '@BIN@/claude-popup help'"

# Touch-friendly (phones/Termux, no function keys needed): TAP the session name
# on the LEFT of the status bar to open the same menu.
bind -n MouseDown1StatusLeft display-menu -T "#[align=centre,bold] claude instances " \
  "Switch instance"      s "choose-tree -Zw" \
  "List instances"       l "display-popup -E -w 84% -h 72% '@BIN@/claude-pick'" \
  "New instance"         n "run-shell '@BIN@/claude-new'" \
  "New in dir…"          d "display-popup -E -w 80% -h 70% '@BIN@/claude-new -D'" \
  "New (model)…"         m "display-popup -E -w 60% -h 50% '@BIN@/claude-model'" \
  "Change dir"           c "display-popup -E -w 80% -h 70% '@BIN@/claude-cd'" \
  "Rename instance"      e "display-popup -E -w 60% -h 28% '@BIN@/claude-rename'" \
  "Shell here"           b "run-shell '@BIN@/claude-shell'" \
  "Resume conversation"  r "run-shell '@BIN@/claude-new -m resume'" \
  "Reopen closed"        o "display-popup -E -w 74% -h 74% '@BIN@/claude-restore'" \
  "Restore last session" a "run-shell '@BIN@/claude-restore-all'" \
  "Stop current"         x "confirm-before -p 'stop instance #W? (y/n)' kill-window" \
  "Cheat sheet"          ? "display-popup -E -w 78% -h 82% '@BIN@/claude-popup help'"

# Navigation synonyms. Alt+arrows are ergonomic but their escape sequences vary
# by terminal (Konsole/GNOME/xterm differ), so F7/F8 are provided as a
# universally-delivered fallback. The menu's "Switch instance" (choose-tree)
# needs no special keys at all and works in every terminal.
bind -n M-Left  previous-window
bind -n M-Right next-window
bind -n F7      previous-window
bind -n F8      next-window

# Keep the active/closed registry fresh when a window closes.
set-hook -g window-unlinked 'run-shell "@BIN@/claude-ls --reconcile-only"'

# Notify when an instance rings the bell (Claude finished / needs input).
set-hook -g alert-bell 'run-shell "@BIN@/claude-notify bell \"#{window_name}\" \"#{session_name}\""'
